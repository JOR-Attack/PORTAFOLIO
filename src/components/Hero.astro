---
---

<section
  class="relative min-h-screen flex flex-col justify-end pb-20 px-8 md:px-16 overflow-hidden bg-ink"
  id="inicio"
>
  <!-- Background grid -->
  <div class="absolute inset-0 opacity-[0.04]"
    style="background-image: linear-gradient(to right, #f5f0e8 1px, transparent 1px), linear-gradient(to bottom, #f5f0e8 1px, transparent 1px); background-size: 60px 60px;">
  </div>

  <!-- Large background number -->
  <div
    class="absolute top-1/2 right-8 md:right-16 -translate-y-1/2 font-display text-[22vw] leading-none text-stroke opacity-30 select-none pointer-events-none"
    aria-hidden="true"
  >
    01
  </div>

  <!-- Accent line -->
  <div class="absolute top-0 left-16 w-px h-full bg-gradient-to-b from-transparent via-accent to-transparent opacity-40"></div>

  <div class="relative z-10 max-w-5xl">
    <!-- Label -->
    <div
      class="flex items-center gap-4 mb-8 opacity-0 animate-fade-up"
      style="animation-delay: 0.2s; animation-fill-mode: forwards;"
    >
      <div class="w-12 h-px bg-accent"></div>
      <span class="font-mono text-xs tracking-[0.3em] uppercase text-accent"
        >Desarrollador Full Stack</span
      >
    </div>

    <!-- Main heading -->
    <h1
      class="font-display text-[18vw] md:text-[12vw] leading-[0.85] mb-8 opacity-0 animate-fade-up"
      style="animation-delay: 0.4s; animation-fill-mode: forwards;"
    >
      <span class="block text-paper">HOLA,</span>
      <span class="block text-stroke">SOY</span>
      <span class="block text-accent">JORGE.</span>
    </h1>

    <!-- Description -->
    <div
      class="flex flex-col md:flex-row md:items-end justify-between gap-8 opacity-0 animate-fade-up"
      style="animation-delay: 0.7s; animation-fill-mode: forwards;"
    >
      <p class="max-w-md font-body text-paper/60 text-lg leading-relaxed">
        Construyo experiencias web modernas y escalables. Apasionado por el
        diseño limpio, el código eficiente y las interfaces que enamoran.
      </p>
      <div class="flex items-center gap-6 shrink-0">
        <a
          href="#proyectos"
          class="group flex items-center gap-3 font-mono text-xs tracking-widest uppercase text-paper hover:text-accent transition-colors duration-300"
        >
          <span>Ver proyectos</span>
          <span
            class="inline-block w-8 h-px bg-current transition-all duration-300 group-hover:w-14"
          ></span>
        </a>
        <a
          href="#contacto"
          class="px-6 py-3 border border-paper/20 font-mono text-xs tracking-widest uppercase text-paper hover:bg-accent hover:border-accent transition-all duration-300"
        >
          Contáctame
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 right-8 md:right-16 flex flex-col items-center gap-2 opacity-0 animate-fade-up"
    style="animation-delay: 1.1s; animation-fill-mode: forwards;"
  >
    <span class="font-mono text-[10px] tracking-[0.3em] uppercase text-paper/30 -rotate-90 mb-4">Scroll</span>
    <div class="w-px h-16 bg-gradient-to-b from-paper/30 to-transparent"></div>
  </div>
</section>
