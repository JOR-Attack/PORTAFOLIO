---
---

<section id="sobre-mi" class="py-32 px-8 md:px-16 bg-paper relative overflow-hidden">

  <!-- Large background text -->
  <div class="absolute top-0 right-0 font-display text-[18vw] leading-none text-ink/5 select-none pointer-events-none translate-x-16">
    ABOUT
  </div>

  <div class="relative z-10 grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-0 items-center">

    <!-- Left: Number + Visual block -->
    <div class="md:col-span-4 md:col-start-1">
      <div class="relative">
        <!-- Photo placeholder -->
        <div class="w-full aspect-[3/4] bg-ink relative overflow-hidden">
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="font-display text-[8rem] text-paper/10">AX</span>
          </div>
          <!-- Diagonal accent -->
          <div class="absolute bottom-0 left-0 right-0 h-1 bg-accent"></div>
          <div class="absolute top-4 left-4 font-mono text-xs tracking-widest text-paper/30">
            FOTO.jpg
          </div>
        </div>

        <!-- Info card -->
        <div class="bg-accent p-6 -mt-8 mr-8 relative z-10">
          <p class="font-mono text-xs tracking-widest uppercase text-paper/80 mb-1">Disponible para</p>
          <p class="font-serif text-xl text-paper">Proyectos freelance</p>
        </div>
      </div>
    </div>

    <!-- Right: Content -->
    <div class="md:col-span-7 md:col-start-6">
      <!-- Label -->
      <div class="flex items-center gap-4 mb-8">
        <div class="w-12 h-px bg-ink/30"></div>
        <span class="font-mono text-xs tracking-[0.3em] uppercase text-ink/50">Sobre mí</span>
      </div>

      <h2 class="font-display text-[10vw] md:text-[5vw] leading-none text-ink mb-8">
        CÓDIGO<br />
        <span class="text-stroke-accent">CON</span><br />
        PROPÓSITO
      </h2>

      <div class="space-y-4 text-ink/70 leading-relaxed max-w-lg">
        <p>
          Soy un desarrollador full stack con más de 4 años de experiencia
          construyendo productos digitales para startups y empresas consolidadas.
        </p>
        <p>
          Me apasiona la intersección entre el diseño y la ingeniería: creo
          que el buen código no solo debe funcionar, sino también ser elegante y
          mantenible.
        </p>
        <p>
          Cuando no estoy programando, probablemente estoy leyendo sobre
          sistemas de diseño, experimentando con nuevas tecnologías o tomando
          café demasiado cargado.
        </p>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-8 mt-12 pt-8 border-t border-ink/10">
        {[
          { value: "4+", label: "Años de experiencia" },
          { value: "30+", label: "Proyectos completados" },
          { value: "15+", label: "Clientes satisfechos" },
        ].map(stat => (
          <div>
            <div class="font-display text-5xl text-ink">{stat.value}</div>
            <div class="font-mono text-xs text-ink/40 uppercase tracking-wider mt-1">{stat.label}</div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-10 flex gap-4">
        <a
          href="/cv.pdf"
          class="inline-flex items-center gap-3 px-6 py-3 bg-ink text-paper font-mono text-xs tracking-widest uppercase hover:bg-accent transition-colors duration-300"
        >
          Descargar CV
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M6 1v7M2 8l4 3 4-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a
          href="https://github.com"
          target="_blank"
          class="inline-flex items-center gap-3 px-6 py-3 border border-ink/20 text-ink font-mono text-xs tracking-widest uppercase hover:border-ink transition-colors duration-300"
        >
          GitHub
        </a>
      </div>
    </div>
  </div>
</section>
